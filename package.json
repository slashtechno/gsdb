{
  "name": "gsdb",
  "version": "1.0.0",
  "description": "Serverless database proxy backed by Google Sheets",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run platform/node.ts",
    "dev:cf": "wrangler dev platform/cloudflare.ts",
    "deploy:cf": "wrangler deploy platform/cloudflare.ts",
    "build": "bun build src/index.ts --outdir dist",
    "db:migrate": "wrangler d1 execute gsdb-db --file=schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.5.0",
    "@hono/zod-openapi": "^0.19.0",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/bun": "latest",
    "@types/node": "^25.9.3",
    "typescript": "^5.8.0"
  }
}
