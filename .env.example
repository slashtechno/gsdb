# Copy to .env.local for local dev

# Google OAuth — create credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Long-lived refresh token — run /auth/login once, copy the token shown on the callback page
GOOGLE_REFRESH_TOKEN=

# Google Sheet ID that stores the app registry (the part after /spreadsheets/d/ in the URL)
# Tab must be named "Apps" — create it with headers: app_id | spreadsheet_id | api_key_hash | created_at
MASTER_SHEET_ID=

# Protects /manage/* routes — set to something random and keep it secret
ADMIN_SECRET=

PORT=3000

# Optional: move all app sheets into this Drive folder (get the ID from the folder URL in Drive)
GDRIVE_FOLDER_ID=

# Optional: S3-compatible file storage (AWS S3, Cloudflare R2, Backblaze B2, MinIO, etc.)
# Leave unset to disable the /files routes (they return 501).
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=          # omit for AWS; set for R2/B2/MinIO (e.g. https://<acct>.r2.cloudflarestorage.com)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
